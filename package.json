  "copyright": "© Mendix Technology BV 2026. All rights reserved.",
  "author": "John",
  "engines": {
    "node": ">=16"
  },
  "license": "Apache-2.0",
  "config": {
    "projectPath": "./tests/testProject",
    "mendixHost": "http://localhost:8080",
    "developmentPort": 3000
  },
  "packagePath": "mendix",
  "scripts": {
    "gleam:build": "gleam build --target javascript",
    "gleam:deps": "gleam deps download",
    "start": "gleam build --target javascript && pluggable-widgets-tools start:server",
    "dev": "gleam build --target javascript && pluggable-widgets-tools start:web",
    "build": "gleam build --target javascript && pluggable-widgets-tools build:web",
    "lint": "pluggable-widgets-tools lint",
    "lint:fix": "pluggable-widgets-tools lint:fix",
    "prerelease": "echo skipping lint",
    "release": "gleam build --target javascript && pluggable-widgets-tools release:web"
  },
  "devDependencies": {
    "@mendix/pluggable-widgets-tools": "^11.8.0"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "resolutions": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
